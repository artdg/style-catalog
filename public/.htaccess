<IfModule mod_rewrite.c>
  RewriteEngine On

  # Serve existing files/directories as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Let PHP API handle /api/*
  RewriteRule ^api/ - [L]

  # SPA fallback
  RewriteRule ^ index.html [L]
</IfModule>

